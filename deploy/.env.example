# Copy to .env next to docker-compose.yml and fill in.

# Hostname pointing at this VPS (A record). Caddy obtains the TLS cert for it.
# No domain yet? Set DOMAIN=:80 to serve plain HTTP and test by IP with curl
# (the website widget needs a real hostname + HTTPS later).
DOMAIN=api.example.com

# Ollama model tag served to the assistant.
OLLAMA_MODEL=qwen2.5:7b

# Comma-separated browser origins allowed to call the API.
API_CORS=https://gemprf.github.io
